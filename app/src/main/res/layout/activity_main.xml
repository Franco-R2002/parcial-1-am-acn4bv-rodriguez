<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondo">

    <LinearLayout
        android:id="@+id/layoutPrincipal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/padding_general"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/titulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/titulo_app"
            android:textSize="@dimen/texto_titulo"
            android:textColor="@color/azul"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/subtitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/subtitulo_app"
            android:textSize="@dimen/texto_normal"
            android:textColor="@color/gris"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="380dp"
            android:src="@drawable/imagen_medica"
            android:scaleType="centerCrop"
            android:contentDescription="Imagen médica"
            android:paddingBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_nombre"
                android:textSize="@dimen/texto_normal"
                android:textColor="@color/azul"
                android:paddingEnd="8dp"
                android:layout_gravity="center_vertical" />

            <EditText
                android:id="@+id/campoNombre"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/hint_nombre"
                android:inputType="textPersonName" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_especialidad"
                android:textSize="@dimen/texto_normal"
                android:textColor="@color/azul"
                android:paddingEnd="8dp"
                android:layout_gravity="center_vertical" />

            <EditText
                android:id="@+id/campoEspecialidad"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/hint_especialidad"
                android:inputType="text" />

        </LinearLayout>

        <Button
            android:id="@+id/botonAgregar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/boton_agregar"
            android:backgroundTint="@color/azul"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/labelLista"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_lista"
            android:textColor="@color/azul"
            android:textStyle="bold"
            android:paddingTop="16dp"
            android:paddingBottom="8dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/contenedorTurnos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </ScrollView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>